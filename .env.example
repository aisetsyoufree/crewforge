# Optional provider API key. CLI providers authenticate through their own tools.
GEMINI_API_KEY=

# Server binding. Defaults to local-only.
CREW_FORGE_HOST=127.0.0.1

# Set to 1 only if you intentionally expose Crew Forge beyond loopback.
# Requires CREW_FORGE_AUTH_TOKEN. This creates a filesystem-browsing and code-execution surface.
CREW_FORGE_ALLOW_REMOTE=0

# Required when CREW_FORGE_ALLOW_REMOTE=1. Use a long random value.
# Open the app once with ?token=<value> or send X-CrewForge-Token / Bearer auth.
CREW_FORGE_AUTH_TOKEN=

# Set to 1 only if you intentionally want to browse/add paths outside the default safe area.
CREW_FORGE_ALLOW_SENSITIVE_PATHS=0

# Automatic stop for stuck provider runs. 0 disables the timeout.
CREW_FORGE_RUN_TIMEOUT_MS=900000
