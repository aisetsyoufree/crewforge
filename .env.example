# Optional provider API key. CLI providers authenticate through their own tools.
GEMINI_API_KEY=

# Server binding. Defaults to local-only.
CREW_FORGE_HOST=127.0.0.1

# Set to 1 only if you intentionally expose Crew Forge beyond loopback.
# This creates a filesystem-browsing and code-execution surface.
CREW_FORGE_ALLOW_REMOTE=0
